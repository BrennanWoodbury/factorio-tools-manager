# Copy to .env and fill in. `docker compose up -d --build` reads this file.

# ---- Web UI auth (REQUIRED) ----
# Password for the single admin login.
ADMIN_PASSWORD=change-me
# Secret used to sign session cookies. Generate one, e.g.: openssl rand -hex 32
JWT_SECRET=

# ---- Published host ports ----
# Manager web UI / API port on the host (prod compose). Container listens on 8080.
WEB_PORT=8080
# Dev compose (docker-compose.dev.yml) only: WEB_PORT is the Vite UI (default 5173)
# and API_PORT is the backend (default 8080). Uncomment to override in dev:
# API_PORT=8080

# ---- Data ----
# Absolute path ON THE HOST to this repo's ./data/servers directory. Required so
# the Factorio containers get a valid host bind-mount source. Example:
#   HOST_SERVERS_DIR=/home/you/factorio-manager/data/servers
HOST_SERVERS_DIR=

# ---- Port pools (must match your router forward) ----
# Contiguous UDP range you forwarded once, manually, on your router to this host.
GAME_PORT_RANGE=34197-34297
# RCON range — loopback only, NOT forwarded, never in DNS.
RCON_PORT_RANGE=27015-27115

# ---- Factorio image / runtime ----
FACTORIO_IMAGE=factoriotools/factorio:stable
# UID/GID the Factorio image runs as (owns the bind-mounted data). Match a host
# user if you care about file ownership; defaults are the image defaults.
PUID=845
PGID=845

# ---- DNS / DDNS via Cloudflare (OPTIONAL) ----
# Leave CLOUDFLARE_API_TOKEN empty to run without DNS automation (players connect
# by IP:port). To enable, all four of the following are required.
# Token needs Zone:DNS:Edit on the zone below (see README for exact permissions).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
# Your apex/base domain, e.g. mydomain.com
BASE_DOMAIN=
# Stable hostname all SRV records target and the DDNS job keeps in sync with your
# public IP, e.g. host.mydomain.com
HOST_RECORD_NAME=
# How often (seconds) to check the public IP and update the host A record.
DDNS_INTERVAL_SECONDS=300
IP_CHECK_URL=https://api.ipify.org
