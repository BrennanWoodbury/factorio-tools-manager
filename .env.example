# Copy to .env and fill in. `docker compose up -d --build` reads this file.

# ---- Web UI auth (REQUIRED) ----
# Password for the single admin login.
ADMIN_PASSWORD=change-me
# Secret used to sign session cookies. Generate one, e.g.: openssl rand -hex 32
JWT_SECRET=

# ---- Published host ports ----
# Manager web UI / API port on the host (prod compose). Container listens on 8080.
WEB_PORT=8080
# Dev compose (docker-compose.dev.yml) only: WEB_PORT is the Vite UI (default 5173)
# and API_PORT is the backend (default 8080). Uncomment to override in dev:
# API_PORT=8080

# ---- Data ----
# Where persistent data lives (SQLite DB + per-server saves/mods/config). It's
# bind-mounted at the same path inside and outside the container, so it just works
# with no other config. Defaults to /opt/factorio-tools-manager; override to
# relocate, e.g. to your home dir:
# FTM_DATA_DIR=/home/you/.factorio-tools-manager

# ---- Port pools (must match your router forward) ----
# Contiguous UDP range you forwarded once, manually, on your router to this host.
GAME_PORT_RANGE=34197-34297
# RCON range — loopback only, NOT forwarded, never in DNS.
RCON_PORT_RANGE=27015-27115

# ---- Factorio image / runtime ----
FACTORIO_IMAGE=factoriotools/factorio:stable
# UID/GID the Factorio image runs as (owns the bind-mounted data). Match a host
# user if you care about file ownership; defaults are the image defaults.
PUID=845
PGID=845

# Stop all Factorio containers when the manager shuts down (e.g. `compose down`).
# Default false: games keep running across a manager restart/update. Set true for
# a clean full shutdown. (Don't enable in the dev stack — hot-reload would stop games.)
STOP_SERVERS_ON_SHUTDOWN=false

# ---- DNS / DDNS via Cloudflare ----
# Configured in the dashboard (DNS / Cloudflare settings), NOT via env. Nothing to
# set here — enter your base domain, host record, zone ID and API token in the UI.
